# Calorcheeky-curator runtime config. Copy this to `.env` (gitignored)
# and fill in.
#
# Read by every script in `scripts/` — fetch-pack.sh / publish-pack.sh
# / pack-history.sh source this file at start, export every var,
# bail with a clear error if anything's missing.

# ── Calorcheeky cloud server ─────────────────────────────────────
# Base URL of your running server. Cloudflare-tunnelled, Tailscale,
# LAN — anything reachable from the box you run the scripts on. No
# trailing slash.
CALORCHEEKY_BASE_URL=https://cloud.calorcheeky.com

# Admin credentials (mirror of the server's `ADMIN_USER` /
# `ADMIN_PASSWORD` env vars). HTTP Basic Auth — both must be set on
# the server side too, or the server returns 404 on `/admin/*` paths.
CALORCHEEKY_ADMIN_USER=admin
CALORCHEEKY_ADMIN_PASSWORD=replace-me

# That's all the curator needs. The AI proposer work happens INSIDE
# Claude Code (this directory's CLAUDE.md is the runbook), so no
# Anthropic API key is required — the operator's Claude Max
# subscription covers it. Zero per-token cost.
