# Calorcheeky-curator runtime config. Copy this to `.env` (gitignored)
# and fill in. Read by `src/app.py` via python-dotenv on startup.

# ── Calorcheeky cloud server ─────────────────────────────────────
# The base URL of your running server. Cloudflare Tunnel makes this
# publicly reachable; you could also use a Tailscale magic URL or
# a LAN address if you only run the curator from inside your home
# network. No trailing slash.
CALORCHEEKY_BASE_URL=https://cloud.calorcheeky.com

# Same admin credentials the server uses (server's `ADMIN_USER` /
# `ADMIN_PASSWORD` env vars). HTTP Basic Auth — both must be
# non-blank or the server returns 404 on /admin/* paths.
CALORCHEEKY_ADMIN_USER=admin
CALORCHEEKY_ADMIN_PASSWORD=replace-me

# ── Anthropic API ────────────────────────────────────────────────
# For the AI proposer (web_search tool). Get yours at
# https://console.anthropic.com/. The curator uses Claude with
# the `web_search_20241222` tool to fetch fresh seasonal product
# data — no static training-data lists.
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

# ── Optional: model override ─────────────────────────────────────
# Defaults to claude-sonnet-4-5-20250929. Pin a specific snapshot
# here when reproducing past proposals or running A/B comparisons.
# CALORCHEEKY_CURATOR_MODEL=claude-sonnet-4-5-20250929
