# Local env file with admin password + Anthropic key. Never commit.
.env
.env.*
!.env.example

# Virtualenv
.venv/
venv/
env/

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Tests / lint
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*

# Streamlit's secrets (we use .env via python-dotenv, but this is the
# convention for the platform's native secrets file — gitignored
# regardless).
.streamlit/secrets.toml

# IDEs
.idea/
.vscode/
*.swp
.DS_Store
